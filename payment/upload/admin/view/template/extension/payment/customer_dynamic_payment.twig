{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-payment" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    <div class="panel panel-default">
      <div class="panel-heading"><h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3></div>
      <div class="panel-body">
        <ul class="nav nav-tabs">
          <li class="active"><a href="#tab-general" data-toggle="tab">{{ tab_general }}</a></li>
          <li><a href="#tab-methods" data-toggle="tab">{{ tab_methods }}</a></li>
          <li><a href="#tab-bindings" data-toggle="tab">{{ tab_bindings }}</a></li>
        </ul>
        <div class="tab-content">
          <div class="tab-pane active" id="tab-general">
            <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-payment" class="form-horizontal">
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-total-min"><span data-toggle="tooltip" title="{{ help_total_min }}">{{ entry_total_min }}</span></label>
                <div class="col-sm-10">
                  <input type="text" name="payment_customer_dynamic_payment_total_min" value="{{ payment_customer_dynamic_payment_total_min }}" placeholder="{{ entry_total_min }}" id="input-total-min" class="form-control" />
                </div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-total-max"><span data-toggle="tooltip" title="{{ help_total_max }}">{{ entry_total_max }}</span></label>
                <div class="col-sm-10">
                  <input type="text" name="payment_customer_dynamic_payment_total_max" value="{{ payment_customer_dynamic_payment_total_max }}" placeholder="{{ entry_total_max }}" id="input-total-max" class="form-control" />
                </div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-geo-zone">{{ entry_geo_zone }}</label>
                <div class="col-sm-10">
                  <select name="payment_customer_dynamic_payment_geo_zone_id" id="input-geo-zone" class="form-control">
                    <option value="0">{{ text_all_zones }}</option>
                    {% for geo_zone in geo_zones %}
                    {% if geo_zone.geo_zone_id == payment_customer_dynamic_payment_geo_zone_id %}
                    <option value="{{ geo_zone.geo_zone_id }}" selected="selected">{{ geo_zone.name }}</option>
                    {% else %}
                    <option value="{{ geo_zone.geo_zone_id }}">{{ geo_zone.name }}</option>
                    {% endif %}
                    {% endfor %}
                  </select>
                </div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
                <div class="col-sm-10">
                  <select name="payment_customer_dynamic_payment_status" id="input-status" class="form-control">
                    {% if payment_customer_dynamic_payment_status %}
                    <option value="1" selected="selected">{{ text_enabled }}</option>
                    <option value="0">{{ text_disabled }}</option>
                    {% else %}
                    <option value="1">{{ text_enabled }}</option>
                    <option value="0" selected="selected">{{ text_disabled }}</option>
                    {% endif %}
                  </select>
                </div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-sort-order">{{ entry_sort_order }}</label>
                <div class="col-sm-10">
                  <input type="text" name="payment_customer_dynamic_payment_sort_order" value="{{ payment_customer_dynamic_payment_sort_order }}" placeholder="{{ entry_sort_order }}" id="input-sort-order" class="form-control" />
                </div>
              </div>
            </form>
          </div>

          <div class="tab-pane" id="tab-methods">
            <p class="help-block">{{ help_methods }}</p>
            {% if edit_method_id %}
            <form action="{{ action }}" method="post" class="form-horizontal well">
              <input type="hidden" name="action" value="edit_method" />
              <input type="hidden" name="method_id" value="{{ edit_method_id }}" />
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_method_name }}</label>
                <div class="col-sm-10">
                  <input type="text" name="method_name" value="{{ edit_method_name }}" class="form-control" required />
                </div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_method_code }}</label>
                <div class="col-sm-10">
                  <input type="text" name="method_code" value="{{ edit_method_code }}" class="form-control" required />
                </div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_method_api_id }}</label>
                <div class="col-sm-10">
                  <input type="text" name="method_api_id" value="{{ edit_method_api_id }}" class="form-control" />
                </div>
              </div>
              <div class="form-group">
                <div class="col-sm-offset-2 col-sm-10">
                  <button type="submit" class="btn btn-primary">{{ button_update_method }}</button>
                  <a href="{{ action }}" class="btn btn-default">{{ button_cancel }}</a>
                </div>
              </div>
            </form>
            {% else %}
            <form action="{{ action }}" method="post" class="form-horizontal well">
              <input type="hidden" name="action" value="add_method" />
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_method_name }}</label>
                <div class="col-sm-10">
                  <input type="text" name="method_name" value="" class="form-control" required />
                </div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_method_code }}</label>
                <div class="col-sm-10">
                  <input type="text" name="method_code" value="" class="form-control" required />
                </div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_method_api_id }}</label>
                <div class="col-sm-10">
                  <input type="text" name="method_api_id" value="" class="form-control" />
                </div>
              </div>
              <div class="form-group">
                <div class="col-sm-offset-2 col-sm-10">
                  <button type="submit" class="btn btn-primary">{{ button_add_method }}</button>
                </div>
              </div>
            </form>
            {% endif %}

            <div class="table-responsive">
              <table class="table table-bordered table-hover">
                <thead>
                  <tr>
                    <td class="text-left">{{ column_method_id }}</td>
                    <td class="text-left">{{ column_name }}</td>
                    <td class="text-left">{{ column_code }}</td>
                    <td class="text-left">{{ column_api_id }}</td>
                    <td class="text-right">{{ column_action }}</td>
                  </tr>
                </thead>
                <tbody>
                  {% if methods %}
                  {% for m in methods %}
                  <tr>
                    <td class="text-left">{{ m.method_id }}</td>
                    <td class="text-left">{{ m.name }}</td>
                    <td class="text-left">{{ m.code }}</td>
                    <td class="text-left">{{ m.api_id }}</td>
                    <td class="text-right">
                      <a href="{{ action }}&edit_method={{ m.method_id }}" data-toggle="tooltip" title="{{ button_edit }}" class="btn btn-primary btn-xs"><i class="fa fa-pencil"></i></a>
                      <form action="{{ action }}" method="post" style="display:inline-block" onsubmit="return confirm('{{ text_confirm_delete }}');">
                        <input type="hidden" name="action" value="delete_method" />
                        <input type="hidden" name="method_id" value="{{ m.method_id }}" />
                        <button type="submit" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger btn-xs"><i class="fa fa-trash-o"></i></button>
                      </form>
                    </td>
                  </tr>
                  {% endfor %}
                  {% else %}
                  <tr>
                    <td class="text-center" colspan="5">{{ text_no_methods }}</td>
                  </tr>
                  {% endif %}
                </tbody>
              </table>
            </div>
          </div>

          <div class="tab-pane" id="tab-bindings">
            <p class="help-block">{{ help_bindings }}</p>
            <form method="get" action="{{ filter_action }}" class="form-inline well" style="margin-bottom:15px;">
              <div class="form-group">
                <input type="text" name="filter_search" value="{{ filter_search }}" placeholder="{{ entry_search }}" class="form-control" style="min-width:280px;" />
              </div>
              <button type="submit" class="btn btn-primary">{{ button_filter }}</button>
            </form>

            <form action="{{ action_bindings }}" method="post" class="form-horizontal well">
              <input type="hidden" name="action" value="add_binding" />
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_customer }}</label>
                <div class="col-sm-10">
                  <input type="text" name="customer" value="" placeholder="{{ entry_customer }}" id="input-customer" class="form-control" />
                  <input type="hidden" name="customer_id" id="input-customer-id" value="" />
                </div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_bind_method }}</label>
                <div class="col-sm-10">
                  <select name="bind_method_id" class="form-control">
                    <option value="0">---</option>
                    {% for m in methods %}
                    <option value="{{ m.method_id }}">{{ m.name }} ({{ m.code }})</option>
                    {% endfor %}
                  </select>
                </div>
              </div>
              <div class="form-group">
                <div class="col-sm-offset-2 col-sm-10">
                  <button type="submit" class="btn btn-primary">{{ button_add_binding }}</button>
                </div>
              </div>
            </form>

            <div class="table-responsive">
              <table class="table table-bordered table-hover">
                <thead>
                  <tr>
                    <td class="text-left">{{ column_bind_id }}</td>
                    <td class="text-left">{{ column_customer }}</td>
                    <td class="text-left">{{ column_email }}</td>
                    <td class="text-left">{{ column_method }}</td>
                    <td class="text-left">{{ column_code }}</td>
                    <td class="text-left">{{ column_api_id }}</td>
                    <td class="text-right">{{ column_action }}</td>
                  </tr>
                </thead>
                <tbody>
                  {% if bindings %}
                  {% for b in bindings %}
                  <tr>
                    <td class="text-left">{{ b.bind_id }}</td>
                    <td class="text-left">{{ b.firstname }} {{ b.lastname }}</td>
                    <td class="text-left">{{ b.email }}</td>
                    <td class="text-left">{{ b.method_name }}</td>
                    <td class="text-left">{{ b.method_code }}</td>
                    <td class="text-left">{{ b.api_id }}</td>
                    <td class="text-right">
                      <form action="{{ action_bindings }}" method="post" style="display:inline-block" onsubmit="return confirm('{{ text_confirm_delete }}');">
                        <input type="hidden" name="action" value="delete_binding" />
                        <input type="hidden" name="bind_id" value="{{ b.bind_id }}" />
                        <button type="submit" class="btn btn-danger btn-xs"><i class="fa fa-trash-o"></i></button>
                      </form>
                    </td>
                  </tr>
                  {% endfor %}
                  {% else %}
                  <tr>
                    <td class="text-center" colspan="7">{{ text_no_bindings }}</td>
                  </tr>
                  {% endif %}
                </tbody>
              </table>
            </div>
            <div class="row">
              <div class="col-sm-6 text-left">{{ pagination }}</div>
              <div class="col-sm-6 text-right">{{ results }}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script type="text/javascript"><!--
$('#input-customer').autocomplete({
  'source': function(request, response) {
    $.ajax({
      url: 'index.php?route=customer/customer/autocomplete&user_token={{ user_token }}&filter_name=' + encodeURIComponent(request),
      dataType: 'json',
      success: function(json) {
        response($.map(json, function(item) {
          return { label: item['name'], value: item['customer_id'] }
        }));
      }
    });
  },
  'select': function(item) {
    $('#input-customer').val(item['label']);
    $('#input-customer-id').val(item['value']);
    return false;
  }
});
//--></script>
{{ footer }}
